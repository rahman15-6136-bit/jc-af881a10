---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-50 border-gray-200 border-t" data-jc-id="9Z7OM8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12" data-jc-id="P7629C">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8" data-jc-id="P76243">
      <!-- Brand -->
      <div class="footer-brand col-span-1 md:col-span-2" data-jc-id="P761F5">
        <a href="/" class="flex items-center gap-2 mb-4" data-jc-id="P760RW">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center" data-jc-id="P760MQ">
            <span class="text-white font-bold text-sm" data-jc-id="P75ZWW">J</span>
          </div>
          <span class="font-bold text-xl text-gray-900" data-jc-id="P75Z7Y">MySite</span>
        </a>
        <p class="text-gray-600 max-w-md" data-jc-id="P75YIY">
          Building amazing digital experiences with modern web technologies.
        </p>
      </div>
      
      <!-- Quick Links -->
      <div class="footer-links" data-jc-id="P75X3C">
        <h3 class="font-semibold text-gray-900 mb-4" data-jc-id="P75X0M">Quick Links</h3>
        <ul class="space-y-2" data-jc-id="P75WCI">
          <li data-jc-id="P75W9U"><a href="/" class="text-gray-600 hover:text-blue-600" data-jc-id="P75W95">Home</a></li>
          <li data-jc-id="060N19"><a href="/about" class="text-gray-600 hover:text-blue-600" data-jc-id="060N1D">About</a></li>
          <li data-jc-id="060NQG"><a href="/contact" class="text-gray-600 hover:text-blue-600" data-jc-id="060NR5">Contact</a></li>
        </ul>
      </div>
      
      <!-- Connect -->
      <div class="footer-social" data-jc-id="060OLB">
        <h3 class="font-semibold text-gray-900 mb-4" data-jc-id="060OO2">Connect</h3>
        <ul class="space-y-2" data-jc-id="060PC2">
          <li data-jc-id="060PEQ"><a href="#" class="text-gray-600 hover:text-blue-600" data-jc-id="060PFF">Twitter</a></li>
          <li data-jc-id="060Q4F"><a href="#" class="text-gray-600 hover:text-blue-600" data-jc-id="060Q4J">GitHub</a></li>
          <li data-jc-id="060QTI"><a href="#" class="text-gray-600 hover:text-blue-600" data-jc-id="060QU7">LinkedIn</a></li>
        </ul>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="footer-bottom border-t border-gray-200 mt-8 pt-8 text-center" data-jc-id="060S6H">
      <p class="text-gray-500 text-sm" data-jc-id="060SDE">
        © {currentYear} MySite. All rights reserved.
      </p>
    </div>
  </div>
</footer>
